@model List<GapWise.Models.Question>
@{
    ViewData["Title"] = "Start Test";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="text-primary mb-4">Your Test</h2>

    <form asp-action="EvaluateTest" method="post">
        <input type="hidden" name="studentTestId" value="@TempData["StudentTestId"]" />

        @for (int i = 0; i < Model.Count; i++)
        {
            var q = Model[i];
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title text-success">Q@(i + 1): @q.Text</h5>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="answers[@q.Id]" value="@q.OptionA" id="q@q.Id-A" />
                        <label class="form-check-label" for="q@q.Id-A">@q.OptionA</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="answers[@q.Id]" value="@q.OptionB" id="q@q.Id-B" />
                        <label class="form-check-label" for="q@q.Id-B">@q.OptionB</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="answers[@q.Id]" value="@q.OptionC" id="q@q.Id-C" />
                        <label class="form-check-label" for="q@q.Id-C">@q.OptionC</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="answers[@q.Id]" value="@q.OptionD" id="q@q.Id-D" />
                        <label class="form-check-label" for="q@q.Id-D">@q.OptionD</label>
                    </div>
                    <div class="progress mt-2">
                        <div class="progress-bar bg-info" role="progressbar" style="width:@((i + 1) * 100 / Model.Count)%"
                             aria-valuenow="@(i + 1)" aria-valuemin="0" aria-valuemax="@Model.Count"></div>
                    </div>
                </div>
            </div>
        }

        <button type="submit" class="btn btn-primary btn-lg w-100">Submit Test</button>
    </form>
</div>